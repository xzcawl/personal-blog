---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="发表文章" description="撰写并发布 Markdown 文章">
  <h1>发表文章</h1>
  <p>
    在下方填写内容后，可<strong>直接发布</strong>到服务器（保存 Markdown、自动构建、立即上线），或下载
    .md 文件后在本地开发环境提交。
  </p>

  <form
    id="publish-form"
    style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem;"
  >
    <label style="display: flex; flex-direction: column; gap: 0.35rem;">
      <span style="font-weight: 600; color: var(--text);">发布密钥（首次填写后会记住）</span>
      <input
        id="field-token"
        type="password"
        placeholder="与服务器 BLOG_TOKEN 一致"
        style="padding: 0.65rem 0.85rem; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 1rem; max-width: 420px;"
      />
    </label>
    <label style="display: flex; flex-direction: column; gap: 0.35rem;">
      <span style="font-weight: 600; color: var(--text);">分类目录</span>
      <select
        id="field-category"
        required
        style="padding: 0.65rem 0.85rem; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 1rem; max-width: 320px;"
      >
        <option value="quant">量化（quant）</option>
        <option value="travel">旅游（travel）</option>
        <option value="life">生活（life）</option>
      </select>
    </label>
    <label style="display: flex; flex-direction: column; gap: 0.35rem;">
      <span style="font-weight: 600; color: var(--text);">标题</span>
      <input
        id="field-title"
        type="text"
        required
        placeholder="文章标题"
        style="padding: 0.65rem 0.85rem; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 1rem;"
      />
    </label>
    <label style="display: flex; flex-direction: column; gap: 0.35rem;">
      <span style="font-weight: 600; color: var(--text);">URL 文件名（英文、连字符）</span>
      <input
        id="field-slug"
        type="text"
        required
        pattern="[a-z0-9]+(?:-[a-z0-9]+)*"
        placeholder="my-new-post"
        style="padding: 0.65rem 0.85rem; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 1rem;"
      />
    </label>
    <label style="display: flex; flex-direction: column; gap: 0.35rem;">
      <span style="font-weight: 600; color: var(--text);">摘要（可选）</span>
      <input
        id="field-description"
        type="text"
        placeholder="一句话简介"
        style="padding: 0.65rem 0.85rem; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 1rem;"
      />
    </label>
    <label style="display: flex; flex-direction: column; gap: 0.35rem;">
      <span style="font-weight: 600; color: var(--text);">发布日期</span>
      <input
        id="field-date"
        type="date"
        required
        style="padding: 0.65rem 0.85rem; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 1rem; max-width: 200px;"
      />
    </label>
    <label style="display: flex; flex-direction: column; gap: 0.35rem;">
      <span style="font-weight: 600; color: var(--text);">更新日期（可选）</span>
      <input
        id="field-updated"
        type="date"
        style="padding: 0.65rem 0.85rem; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 1rem; max-width: 200px;"
      />
    </label>
    <label style="display: flex; flex-direction: column; gap: 0.35rem;">
      <span style="font-weight: 600; color: var(--text);">正文（Markdown）</span>
      <textarea
        id="field-body"
        required
        rows="16"
        placeholder="在这里写 Markdown 正文..."
        style="padding: 0.85rem; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 0.95rem; font-family: ui-monospace, monospace; resize: vertical;"
      ></textarea>
    </label>
    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
      <button
        type="button"
        id="btn-publish"
        style="padding: 0.65rem 1.25rem; border-radius: var(--radius); border: none; background: var(--accent); color: #0f1419; font-weight: 600; cursor: pointer; font-size: 1rem;"
      >
        直接发布
      </button>
      <button
        type="submit"
        style="padding: 0.65rem 1.25rem; border-radius: var(--radius); border: 1px solid var(--border); background: transparent; color: var(--text); cursor: pointer; font-size: 1rem;"
      >
        下载 .md 文件
      </button>
      <button
        type="button"
        id="btn-copy"
        style="padding: 0.65rem 1.25rem; border-radius: var(--radius); border: 1px solid var(--border); background: transparent; color: var(--text); cursor: pointer; font-size: 1rem;"
      >
        复制全文
      </button>
    </div>
    <p id="msg" style="min-height: 1.5rem; margin: 0; font-size: 0.9rem;"></p>
  </form>

  <section style="margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border);">
    <h2 style="font-size: 1.1rem; margin: 0 0 1rem;">或直接上传已有 .md 文件</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
      <select
        id="upload-category"
        style="padding: 0.65rem 0.85rem; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 1rem;"
      >
        <option value="quant">量化（quant）</option>
        <option value="travel">旅游（travel）</option>
        <option value="life">生活（life）</option>
      </select>
      <input id="upload-file" type="file" accept=".md,text/markdown" />
      <button
        type="button"
        id="btn-upload"
        style="padding: 0.65rem 1.25rem; border-radius: var(--radius); border: none; background: var(--accent); color: #0f1419; font-weight: 600; cursor: pointer; font-size: 1rem;"
      >
        上传并发布
      </button>
    </div>
    <p id="upload-msg" style="min-height: 1.5rem; margin: 0.75rem 0 0; font-size: 0.9rem;"></p>
  </section>

  <script>
    const TOKEN_KEY = 'blog-publish-token';

    function escapeYaml(s) {
      return s.replace(/"/g, '\\"');
    }

    function getToken() {
      const input = document.getElementById('field-token');
      const value = input && 'value' in input ? input.value.trim() : '';
      if (value) localStorage.setItem(TOKEN_KEY, value);
      return value || localStorage.getItem(TOKEN_KEY) || '';
    }

    function buildMarkdown() {
      const titleEl = document.getElementById('field-title');
      const slugEl = document.getElementById('field-slug');
      const categoryEl = document.getElementById('field-category');
      const descEl = document.getElementById('field-description');
      const dateEl = document.getElementById('field-date');
      const updatedEl = document.getElementById('field-updated');
      const bodyEl = document.getElementById('field-body');
      if (!titleEl || !slugEl || !categoryEl || !dateEl || !bodyEl) return null;

      const title = titleEl.value.trim();
      const slug = slugEl.value.trim().toLowerCase();
      const category = categoryEl.value;
      const description = descEl ? descEl.value.trim() : '';
      const date = dateEl.value;
      const updated = updatedEl ? updatedEl.value : '';
      const body = bodyEl.value.trim();

      if (!title || !slug || !date || !body) return null;

      const descLine = description
        ? `description: "${escapeYaml(description)}"\n`
        : '';
      const updatedLine = updated ? `updated: ${updated}\n` : '';
      const content =
        '---\n' +
        `title: "${escapeYaml(title)}"\n` +
        `date: ${date}\n` +
        updatedLine +
        descLine +
        '---\n\n' +
        body +
        '\n';
      return { filename: slug + '.md', content, category };
    }

    async function publishToServer(result, msgEl) {
      const token = getToken();
      if (!token) {
        if (msgEl) {
          msgEl.textContent = '请先填写发布密钥（BLOG_TOKEN）。';
          msgEl.style.color = '#e88';
        }
        return;
      }
      if (msgEl) {
        msgEl.textContent = '正在发布并构建站点，请稍候…';
        msgEl.style.color = 'var(--muted)';
      }
      try {
        const res = await fetch('/api/blog/publish', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify(result),
        });
        const data = await res.json();
        if (!res.ok || !data.success) {
          throw new Error(data.error || '发布失败');
        }
        if (msgEl) {
          msgEl.innerHTML =
            '发布成功！<a href="' +
            data.url +
            '" style="color: var(--accent);">查看文章</a> · ' +
            '<a href="/" style="color: var(--accent);">返回列表</a>';
          msgEl.style.color = 'var(--muted)';
        }
      } catch (err) {
        if (msgEl) {
          msgEl.textContent =
            err instanceof Error ? err.message : '发布失败，请检查密钥与服务器状态。';
          msgEl.style.color = '#e88';
        }
      }
    }

    const form = document.getElementById('publish-form');
    const msg = document.getElementById('msg');
    const tokenInput = document.getElementById('field-token');
    const savedToken = localStorage.getItem(TOKEN_KEY);
    if (tokenInput && 'value' in tokenInput && savedToken) {
      tokenInput.value = savedToken;
    }

    document.getElementById('btn-publish')?.addEventListener('click', async () => {
      const result = buildMarkdown();
      if (!result) {
        if (msg) {
          msg.textContent = '请填写所有必填项，且文件名仅使用小写字母、数字与连字符。';
          msg.style.color = '#e88';
        }
        return;
      }
      await publishToServer(result, msg);
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const result = buildMarkdown();
      if (!result || !msg) {
        if (msg) {
          msg.textContent =
            '请填写所有必填项，且文件名仅使用小写字母、数字与连字符。';
          msg.style.color = '#e88';
        }
        return;
      }
      const blob = new Blob([result.content], {
        type: 'text/markdown;charset=utf-8',
      });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = result.filename;
      a.click();
      URL.revokeObjectURL(a.href);
      msg.textContent = '已下载 ' + result.filename + '。';
      msg.style.color = 'var(--muted)';
    });

    document.getElementById('btn-copy')?.addEventListener('click', async () => {
      const result = buildMarkdown();
      if (!result || !msg) {
        if (msg) {
          msg.textContent = '请填写所有必填项。';
          msg.style.color = '#e88';
        }
        return;
      }
      try {
        await navigator.clipboard.writeText(result.content);
        msg.textContent = '已复制到剪贴板。';
        msg.style.color = 'var(--muted)';
      } catch {
        msg.textContent = '复制失败，请使用下载文件。';
        msg.style.color = '#e88';
      }
    });

    document.getElementById('btn-upload')?.addEventListener('click', async () => {
      const uploadMsg = document.getElementById('upload-msg');
      const fileInput = document.getElementById('upload-file');
      const categoryEl = document.getElementById('upload-category');
      const token = getToken();
      if (!token) {
        if (uploadMsg) {
          uploadMsg.textContent = '请先填写发布密钥（BLOG_TOKEN）。';
          uploadMsg.style.color = '#e88';
        }
        return;
      }
      if (!fileInput || !('files' in fileInput) || !fileInput.files || fileInput.files.length === 0) {
        if (uploadMsg) {
          uploadMsg.textContent = '请先选择一个 .md 文件。';
          uploadMsg.style.color = '#e88';
        }
        return;
      }
      const file = fileInput.files[0];
      const category = categoryEl && 'value' in categoryEl ? categoryEl.value : 'quant';
      if (uploadMsg) {
        uploadMsg.textContent = '正在上传并构建站点，请稍候…';
        uploadMsg.style.color = 'var(--muted)';
      }
      try {
        const content = await file.text();
        const params = new URLSearchParams({
          category,
          filename: file.name,
        });
        const res = await fetch('/api/blog/upload?' + params.toString(), {
          method: 'POST',
          headers: {
            'Content-Type': 'text/markdown; charset=utf-8',
            Authorization: `Bearer ${token}`,
          },
          body: content,
        });
        const data = await res.json();
        if (!res.ok || !data.success) {
          throw new Error(data.error || '上传失败');
        }
        if (uploadMsg) {
          uploadMsg.innerHTML =
            '上传成功！<a href="' +
            data.url +
            '" style="color: var(--accent);">查看文章</a>';
          uploadMsg.style.color = 'var(--muted)';
        }
      } catch (err) {
        if (uploadMsg) {
          uploadMsg.textContent =
            err instanceof Error ? err.message : '上传失败，请检查文件格式与密钥。';
          uploadMsg.style.color = '#e88';
        }
      }
    });

    const today = new Date().toISOString().slice(0, 10);
    const dateInput = document.getElementById('field-date');
    if (dateInput && 'value' in dateInput && !dateInput.value) {
      dateInput.value = today;
    }
    const updatedInput = document.getElementById('field-updated');
    if (updatedInput && 'value' in updatedInput && !updatedInput.value) {
      updatedInput.value = today;
    }
  </script>
</BaseLayout>
