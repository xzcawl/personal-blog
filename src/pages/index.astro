---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('blog');
const posts = all
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="文章列表" description="个人博客文章列表">
  <h1>文章列表</h1>
  <p style="margin-bottom: 2rem;">
    共 {posts.length} 篇。要发布新文章，请前往
    <a href={`${base}publish`}>发表文章</a>。
  </p>
  <ul style="list-style: none; padding: 0; margin: 0;">
    {
      posts.map((post) => (
        <li
          style="border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem 1.25rem; margin-bottom: 1rem; background: var(--surface);"
        >
          <a
            href={`${base}blog/${post.slug}/`}
            style="font-size: 1.1rem; font-weight: 600; color: var(--text);"
          >
            {post.data.title}
          </a>
          {post.data.description && (
            <p style="margin: 0.5rem 0 0; font-size: 0.95rem;">{post.data.description}</p>
          )}
          <time
            datetime={post.data.date.toISOString()}
            style="display: block; margin-top: 0.5rem; font-size: 0.85rem; color: var(--muted);"
          >
            {post.data.date.toLocaleDateString('zh-CN')}
          </time>
        </li>
      ))
    }
  </ul>
</BaseLayout>
