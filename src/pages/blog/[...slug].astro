---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({
      params: { slug: post.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const base = import.meta.env.BASE_URL;
const updatedAt = post.data.updated ?? post.data.date;
const sameDay = updatedAt.toDateString() === post.data.date.toDateString();
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    <p style="margin-bottom: 0.5rem;">
      <a href={`${base}`}>← 返回列表</a>
    </p>
    <h1>{post.data.title}</h1>
    <p style="margin-bottom: 1.5rem; color: var(--muted); font-size: 0.9rem;">
      发布于
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
      {!sameDay && (
        <>
          {' '}· 更新于{' '}
          <time datetime={updatedAt.toISOString()}>
            {updatedAt.toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </>
      )}
    </p>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    color: var(--text);
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    line-height: 1.35;
  }

  .prose :global(h2) {
    color: var(--text);
  }

  .prose :global(p) {
    color: var(--text);
    margin: 0.8rem 0;
  }

  .prose :global(li) {
    color: var(--text);
    margin: 0.25rem 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.25rem;
    margin: 0.75rem 0;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: var(--accent-hover);
  }

  .prose :global(blockquote) {
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    border-left: 4px solid var(--border);
    background: var(--surface);
    color: var(--muted);
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 1.5rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    display: block;
    overflow-x: auto;
  }

  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .prose :global(th) {
    background: var(--surface);
    color: var(--text);
  }

  .prose :global(code) {
    font-family: ui-monospace, "Cascadia Code", monospace;
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose :global(pre) {
    background: var(--surface);
    padding: 1rem;
    border-radius: var(--radius);
    overflow-x: auto;
  }

  .prose :global(pre code) {
    padding: 0;
    background: none;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
  }

  .prose :global(input[type='checkbox']) {
    transform: translateY(1px);
  }
</style>
